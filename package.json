{
  "name": "pharmaqms",
  "private": true,
  "version": "4.2.15",
  "description": "Enterprise Pharmaceutical Quality Management System",
  "author": "Dr. Daoud Tajeldeinn",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "app/main.cjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"cd app && npm run dev\" \"wait-on tcp:localhost:5173 && electron .\" --kill-others --success first",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"cd app && npm run dev\" \"wait-on tcp:localhost:5173 && electron .\" --kill-others --success first",
    "build": "npm run build:app && node -e \"require('fs').cpSync('app/dist', 'dist', {recursive:true, force:true})\"",
    "vercel-build": "npm run build",
    "build:app": "cd app && npm install && npm run build",
    "electron:build": "npm run build && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "build": {
    "appId": "com.pharmaqms.enterprise",
    "productName": "PharmaQMS Enterprise",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "app/public/icons/icon-512x512.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PharmaQMS Enterprise"
    },
    "files": [
      "main.cjs",
      "dist/**/*"
    ],
    "publish": [
      {
        "provider": "github"
      }
    ]
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron-updater": "^6.8.3",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "wait-on": "^9.0.4"
  }
}
